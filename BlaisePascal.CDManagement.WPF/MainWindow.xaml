<Window x:Class="BlaisePascal.CDManagement.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BlaisePascal.CDManagement.WPF"
        mc:Ignorable="d"
         Title="[ CD MANAGEMENT v2.0 ] — BlaisePascal"
        Height="760" Width="1080"
        MinHeight="660" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        Background="#050A05"
        BorderBrush="#00FF41"
        BorderThickness="1">
    <Window.Resources>
        <!-- Glow verde per testi titolo -->
        <Style x:Key="GlowTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00FF41"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00FF41" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DimInfo" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="#00AA2A"/>
        </Style>

        <!-- Separatore orizzontale neon -->
        <Style x:Key="NeonSep" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Fill">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent"    Offset="0"/>
                        <GradientStop Color="#00FF41"         Offset="0.3"/>
                        <GradientStop Color="#00FF41"         Offset="0.7"/>
                        <GradientStop Color="Transparent"    Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             HEADER — striscia superiore stile rack player
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#001500" Offset="0"/>
                    <GradientStop Color="#050A05" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00FF41" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>

            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / titolo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- "LED" decorativi -->
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse Width="7" Height="7" Margin="0,2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#00FF41" Offset="0"/>
                                    <GradientStop Color="#003300" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00FF41" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="7" Height="7" Margin="0,2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#CC00FF" Offset="0"/>
                                    <GradientStop Color="#1A0033" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#CC00FF" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="7" Height="7" Margin="0,2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#00FFFF" Offset="0"/>
                                    <GradientStop Color="#001A1A" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="▶ CD MANAGEMENT" FontFamily="Courier New"
                                   FontSize="22" FontWeight="Bold" Foreground="#00FF41">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FF41" BlurRadius="14" ShadowDepth="0" Opacity="1"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="[ BLAISEPASCAL AUDIO SYSTEM v2.0 ]"
                                   FontFamily="Courier New" FontSize="9"
                                   Foreground="#00AA2A"/>
                    </StackPanel>
                </StackPanel>

                <!-- EQ bars decorative -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,8">
                    <Rectangle Width="4" Height="28" Fill="#00FF41" Margin="2,0" Opacity="0.9">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="5" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Rectangle Width="4" Height="18" Fill="#00FF41" Margin="2,0" Opacity="0.7"/>
                    <Rectangle Width="4" Height="35" Fill="#00FF41" Margin="2,0" Opacity="0.9">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="5" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Rectangle Width="4" Height="12" Fill="#00CC33" Margin="2,0" Opacity="0.6"/>
                    <Rectangle Width="4" Height="40" Fill="#00FF41" Margin="2,0" Opacity="1">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="8" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Rectangle Width="4" Height="22" Fill="#00FF41" Margin="2,0" Opacity="0.7"/>
                    <Rectangle Width="4" Height="30" Fill="#66FF66" Margin="2,0" Opacity="0.8">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="5" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Rectangle Width="4" Height="15" Fill="#00CC33" Margin="2,0" Opacity="0.6"/>
                    <Rectangle Width="4" Height="45" Fill="#00FF41" Margin="2,0" Opacity="1">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="10" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Rectangle Width="4" Height="20" Fill="#00FF41" Margin="2,0" Opacity="0.7"/>
                    <Rectangle Width="4" Height="33" Fill="#00FF41" Margin="2,0" Opacity="0.8"/>
                    <Rectangle Width="4" Height="10" Fill="#00AA2A" Margin="2,0" Opacity="0.5"/>
                    <Rectangle Width="4" Height="38" Fill="#00FF41" Margin="2,0" Opacity="0.9">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="5" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </StackPanel>

                <!-- Orologio / info angolo destro -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="■ ONLINE" FontFamily="Courier New" FontSize="9"
                               Foreground="#00FF41" HorizontalAlignment="Right">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="6" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="DSP: ACTIVE" FontFamily="Courier New" FontSize="8" Foreground="#00AA2A" HorizontalAlignment="Right"/>
                    <TextBlock Text="FORMAT: CD-A" FontFamily="Courier New" FontSize="8" Foreground="#007A1F" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Linea neon sotto header -->
        <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="2">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#00FF41"      Offset="0.2"/>
                    <GradientStop Color="#66FFAA"      Offset="0.5"/>
                    <GradientStop Color="#00FF41"      Offset="0.8"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <DropShadowEffect Color="#00FF41" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
            </Rectangle.Effect>
        </Rectangle>

        <!-- ══════════════════════════════════════════════════════════
             CONTENUTO PRINCIPALE
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── PANNELLO SINISTRO ──────────────────────────────── -->
            <StackPanel Grid.Column="0">

                <!-- Crea Brano -->
                <GroupBox Header="[ + ] NUOVO BRANO">
                    <StackPanel>
                        <Label Content="TITOLO *"/>
                        <TextBox x:Name="TxtBranoTitolo"/>
                        <Label Content="ARTISTA *"/>
                        <TextBox x:Name="TxtBranoArtista"/>
                        <Label Content="DURATA (sec) *"/>
                        <TextBox x:Name="TxtBranoDurata"/>
                        <Rectangle Style="{StaticResource NeonSep}" Margin="0,6,0,4"/>
                        <Button Content="▶  CREA BRANO" 
                                Margin="0,2,0,0" Click="BtnCreaBrano_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Crea CD -->
                <GroupBox Header="[ ◉ ] NUOVO CD">
                    <StackPanel>
                        <Label Content="TITOLO CD *"/>
                        <TextBox x:Name="TxtCdTitolo"/>
                        <Label Content="ARTISTA CD *"/>
                        <TextBox x:Name="TxtCdArtista"/>
                        <Rectangle Style="{StaticResource NeonSep}" Margin="0,6,0,4"/>
                        <Button Content="◉  CREA CD" 
                                Margin="0,2,0,0" Click="BtnCreaCD_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Gestione tracce -->
                <GroupBox Header="[ ♫ ] GESTIONE TRACCE">
                    <StackPanel>
                        <Label Content="SELEZIONA CD"/>
                        <ComboBox x:Name="CmbCD" DisplayMemberPath="Titolo"
                                  Height="28" Margin="0,0,0,6"
                                  SelectionChanged="CmbCD_SelectionChanged"/>
                        <Label Content="SELEZIONA BRANO"/>
                        <ComboBox x:Name="CmbBrano" Height="28" Margin="0,0,0,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Courier New" FontSize="11" Foreground="#00FF41"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Rectangle Style="{StaticResource NeonSep}" Margin="0,4,0,4"/>
                        <Button Content="▶  AGGIUNGI AL CD" 
                                Margin="0,2,0,4" Click="BtnAggiungiBrano_Click"/>
                        <Button Content="✕  RIMUOVI BRANO" 
                                Click="BtnRimuoviBrano_Click"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

            <!-- Separatore verticale neon -->
            <Grid Grid.Column="1">
                <Rectangle Width="1" VerticalAlignment="Stretch">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#00FF41"      Offset="0.3"/>
                            <GradientStop Color="#00FF41"      Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#00FF41" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <!-- ─── PANNELLO DESTRO ────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Intestazione lista brani -->
                <Border Grid.Row="0" Background="#001500" BorderBrush="#007A1F"
                        BorderThickness="1" CornerRadius="2" Padding="8,5" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="▶ BRANI DISPONIBILI" Style="{StaticResource GlowTitle}" Margin="0"/>
                        <TextBlock x:Name="TxtCountBrani" Grid.Column="1"
                                   Style="{StaticResource DimInfo}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista brani -->
                <ListBox Grid.Row="1" x:Name="ListBrani"
                         Margin="0,0,0,8"
                         SelectionChanged="ListBrani_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Titolo, Mode=OneWay}"
                                               FontFamily="Courier New" FontWeight="Bold"
                                               FontSize="12" Foreground="#00FF41"/>
                                    <TextBlock FontFamily="Courier New" FontSize="10" Foreground="#00AA2A">
                                        <Run Text="{Binding Artista, Mode=OneWay}"/>
                                        <Run Text="  ·  "/>
                                        <Run Text="{Binding Genere, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" Margin="6,0,0,0"
                                        Background="#001500" BorderBrush="#00AA2A"
                                        BorderThickness="1" CornerRadius="2" Padding="5,2">
                                    <TextBlock Text="{Binding DurataFormattata, Mode=OneWay}"
                                               FontFamily="Courier New" FontSize="11"
                                               Foreground="#00FF41" FontWeight="Bold">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#00FF41" BlurRadius="4" ShadowDepth="0" Opacity="0.7"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Intestazione brani CD -->
                <Border Grid.Row="2" Background="#001500" BorderBrush="#007A1F"
                        BorderThickness="1" CornerRadius="2" Padding="8,5" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="◉ TRACCE NEL CD" Style="{StaticResource GlowTitle}" Margin="0"/>
                        <TextBlock x:Name="TxtInfoCD" Grid.Column="1"
                                   Style="{StaticResource DimInfo}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- Lista tracce CD -->
                <ListBox Grid.Row="3" x:Name="ListBraniCD">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Numero traccia (decorativo) -->
                                <Border Grid.Column="0" Width="22" Height="22" Margin="0,0,8,0"
                                        BorderBrush="#00AA2A" BorderThickness="1" CornerRadius="1">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#003300" Offset="0"/>
                                            <GradientStop Color="#001500" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="▶" FontSize="8" Foreground="#00FF41"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#00FF41" BlurRadius="4" ShadowDepth="0"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Titolo, Mode=OneWay}"
                                               FontFamily="Courier New" FontWeight="Bold"
                                               FontSize="12" Foreground="#00FF41"/>
                                    <TextBlock Text="{Binding Artista, Mode=OneWay}"
                                               FontFamily="Courier New" FontSize="10" Foreground="#00AA2A"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DurataFormattata, Mode=OneWay}"
                                           FontFamily="Courier New" FontSize="11"
                                           Foreground="#00CC33" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Ricerca artista -->
                <GroupBox Grid.Row="4" Header="[ 🔍 ] RICERCA PER ARTISTA NEL CD" Margin="0,8,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtRicercaArtista" Grid.Column="0"/>
                            <Button Grid.Column="2" Content="▶ CERCA"    
                                    Click="BtnCercaArtista_Click"/>
                        </Grid>
                        <TextBlock x:Name="TxtRisultatoRicerca"
                                   Margin="0,6,0,0"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#00CC33" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             STATUS BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#001500" Offset="0"/>
                    <GradientStop Color="#050A05" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#00AA2A"      Offset="0.2"/>
                    <GradientStop Color="#00AA2A"      Offset="0.8"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>0,1,0,0</Border.BorderThickness>

            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="▶ " Foreground="#00FF41" FontFamily="Courier New"
                           FontSize="11" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FF41" BlurRadius="5" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="TxtStatus" Grid.Column="1"
                           Text="SISTEMA PRONTO"
                           Foreground="#00AA2A" FontFamily="Courier New"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="DSP ■■■■■ 100%"
                           FontFamily="Courier New" FontSize="9"
                           Foreground="#007A1F" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
